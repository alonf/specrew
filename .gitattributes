# Squad: union merge for append-only team state files
.squad/decisions.md merge=union
.squad/agents/*/history.md merge=union
.squad/log/** merge=union
.squad/orchestration-log/** merge=union

# Agent-edited text artifacts stay LF across Windows, WSL, and Linux hosts.
.gitattributes text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# feature 140: Unix wrappers + bootstrap are POSIX sh and MUST stay LF (overrides core.autocrlf)
bin/* text eol=lf
install.sh text eol=lf
tests/integration/*.sh text eol=lf
tests/fixtures/install-sh/** text eol=lf

# feature 197: byte-identical transcript-parse goldens MUST stay LF (the -Raw packet preserves \n);
# a CRLF flip on a fresh checkout would silently break the #2885 parse-once regression guard (T072).
tests/continuous-co-review/unit/fixtures/**/*.golden.txt text eol=lf
